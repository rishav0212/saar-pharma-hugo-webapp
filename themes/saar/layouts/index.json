{{- $index := slice -}}

{{/* 1. Standard Pages & Articles (Enhanced with Product Deep-Indexing) */}}
{{- range .Site.AllPages -}}
  {{- if and (ne .Kind "taxonomy") (ne .Kind "term") (ne .Title "") -}}
    {{- $summary := .Summary | plainify -}}
    {{- if .IsHome -}}{{- $summary = "Leading WHO-GMP & ISO certified pharmaceutical manufacturer specializing in oral liquids, ointments, and drops." -}}{{- end -}}
    
    {{/* Combine technical content for deep searching */}}
    {{- $deepContent := .Plain -}}
    {{- if eq .Type "products" -}}
      {{- $cats := "" -}}
      {{- if .Params.categories }}{{ $cats = delimit .Params.categories " " }}{{ end -}}
      {{- $deepContent = printf "%s %s %s %s" $deepContent $cats (.Params.composition | default "") (.Params.dosage_form | default "") -}}
    {{- end -}}

    {{- $item := dict "title" .Title "permalink" .RelPermalink "summary" $summary "content" ($deepContent | truncate 2000) "type" .Type "weight" 1 -}}
    {{- $index = $index | append $item -}}
  {{- end -}}
{{- end -}}

{{/* 2. Deep Sections from Homepage (Migrated to Params) */}}
{{- $home := .Site.Home.Params -}}

{{- range $home.categories -}}
  {{- $tags := "" -}}
  {{- if .tags }}{{ $tags = delimit .tags " " }}{{ end -}}
  {{- $item := dict "title" .title "permalink" (.url | default "/#categories") "summary" .text "content" $tags "type" "Category" "weight" 10 -}}
  {{- $index = $index | append $item -}}
{{- end -}}

{{- range $home.products -}}
  {{- $item := dict "title" .title "permalink" (.url | default "/#products") "summary" .text "content" .type "type" "Range" "weight" 10 -}}
  {{- $index = $index | append $item -}}
{{- end -}}

{{- range $home.why -}}
  {{- $item := dict "title" .title "permalink" "/#why" "summary" .text "content" "" "type" "Advantage" "weight" 10 -}}
  {{- $index = $index | append $item -}}
{{- end -}}

{{- range $home.units -}}
  {{- $item := dict "title" .name "permalink" "/#manufacturing" "summary" (printf "%s - %s" .focus .capacity) "content" "" "type" "Unit" "weight" 10 -}}
  {{- $index = $index | append $item -}}
{{- end -}}

{{- range $home.process -}}
  {{- $item := dict "title" .title "permalink" "/#process" "summary" .text "content" "" "type" "Process" "weight" 10 -}}
  {{- $index = $index | append $item -}}
{{- end -}}

{{- range $home.articles -}}
  {{- $item := dict "title" .title "permalink" .url "summary" .desc "content" .cat "type" "Article" "weight" 10 -}}
  {{- $index = $index | append $item -}}
{{- end -}}

{{- range $home.faqs -}}
  {{- $item := dict "title" .q "permalink" "/#faq" "summary" .a "content" "" "type" "FAQ" "weight" 10 -}}
  {{- $index = $index | append $item -}}
{{- end -}}

{{- $index | jsonify -}}
