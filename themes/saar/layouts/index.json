{{- $index := slice -}}

{{/* 1. Standard Pages & Articles (Weight: 1 - Highest Priority) */}}
{{- range .Site.AllPages -}}
  {{- if and (ne .Kind "taxonomy") (ne .Kind "term") (ne .Title "") -}}
    {{- $summary := .Summary | plainify -}}
    {{- if .IsHome -}}{{- $summary = "Leading WHO-GMP & ISO certified pharmaceutical manufacturer specializing in oral liquids, ointments, and drops." -}}{{- end -}}
    {{- $item := dict "title" .Title "permalink" .RelPermalink "summary" $summary "content" (.Plain | truncate 800) "type" .Type "weight" 1 -}}
    {{- $index = $index | append $item -}}
  {{- end -}}
{{- end -}}

{{/* 2. Deep Sections (Weight: 10 - Lower Priority) */}}
{{- $home := .Site.Data.home -}}

{{- range $home.categories -}}
  {{- $item := dict "title" .title "permalink" (.url | default "/#categories") "summary" .text "content" (delimit .tags " ") "type" "Category" "weight" 10 -}}
  {{- $index = $index | append $item -}}
{{- end -}}

{{- range $home.products -}}
  {{- $item := dict "title" .title "permalink" (.url | default "/#products") "summary" .text "content" .type "type" "Range" "weight" 10 -}}
  {{- $index = $index | append $item -}}
{{- end -}}

{{- range $home.why -}}
  {{- $item := dict "title" .title "permalink" "/#why" "summary" .text "content" "" "type" "Advantage" "weight" 10 -}}
  {{- $index = $index | append $item -}}
{{- end -}}

{{- range $home.units -}}
  {{- $item := dict "title" .name "permalink" "/#manufacturing" "summary" (printf "%s - %s" .focus .capacity) "content" "" "type" "Unit" "weight" 10 -}}
  {{- $index = $index | append $item -}}
{{- end -}}

{{- range $home.process -}}
  {{- $item := dict "title" .title "permalink" "/#process" "summary" .text "content" "" "type" "Process" "weight" 10 -}}
  {{- $index = $index | append $item -}}
{{- end -}}

{{- range $home.articles -}}
  {{- $item := dict "title" .title "permalink" .url "summary" .desc "content" .cat "type" "Article" "weight" 10 -}}
  {{- $index = $index | append $item -}}
{{- end -}}

{{- range $home.faqs -}}
  {{- $item := dict "title" .q "permalink" "/#faq" "summary" .a "content" "" "type" "FAQ" "weight" 10 -}}
  {{- $index = $index | append $item -}}
{{- end -}}

{{- $index | jsonify -}}
